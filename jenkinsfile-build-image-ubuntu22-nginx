pipeline {
    agent any
       stages {
          stage('CleanUp de Workspace'){
             steps {
                cleanWs()
             }
         }
        stage('Cloner le GitHub'){
           steps {
                 git branch: 'main', url: 'https://github.com/Avigneswaran08/projetdev_local.git'
            }
         }
        stage('install Docker'){
          steps {
            sh 'sudo apt remove $(dpkg --get-selections docker.io docker-compose docker-compose-v2 docker-doc podman-docker containerd runc | cut -f1 -y)'
            sh 'sudo apt update'
            sh 'sudo apt install apt-transport-https ca-certificates curl software-properties-common -y'
            sh 'sudo apt install docker.io -y'
            sh 'sudo apt update'
            sh 'sudo chmod 666 /var/run/docker.sock'
            sh 'sudo usermod -aG docker $USER'
            sh 'sudo systemctl restart docker.service'
          }
        }
         stage('build-image Ubuntu/nginx') {
           steps {
             scripts {
               sh 'docker build -t mynginx .'
               sh 'docker image ls'
             }
          }
        }
      }
}
